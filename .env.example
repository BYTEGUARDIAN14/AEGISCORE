# AEGISCORE — Environment Configuration
# Copy to .env and modify for your deployment.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegiscore:aegiscore_secret@localhost:5432/aegiscore

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-strong-random-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=AEGISCORE
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
API_V1_PREFIX=/api/v1

# ── Ollama (Local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:7b
OLLAMA_TIMEOUT=120

# ── ML Model ────────────────────────────────────────────────────────────────
ML_MODEL_PATH=./models/risk_model.pkl
ML_RETRAIN_EVERY_N_SCANS=50
ML_MIN_TRAINING_SAMPLES=50

# ── Scanners ─────────────────────────────────────────────────────────────────
SEMGREP_RULES=p/owasp-top-ten

# ── Celery ──────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4

# ── Slack Alerts ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_ALERT_SEVERITY=CRITICAL

# ── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
