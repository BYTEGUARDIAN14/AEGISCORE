# AEGISCORE — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.venv/
venv/
env/

# Node
node_modules/
npm-debug.log*

# Build outputs
frontend/dist/

# Environment
.env
.env.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# ML artifacts
*.pkl
models/*.pkl

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Alembic
migrations/versions/*.py
!migrations/versions/__init__.py

# Auth tokens
.aegiscore_token
